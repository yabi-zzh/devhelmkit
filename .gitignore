.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# 类型检查
.mypy_cache/
.pyre/
.pytype/

# 日志与临时文件
*.log
logs/
tmp/
*.tmp

# 设备端产物（不应入库）
*.hprof

# 本地测试与文档（不入库，PyPI 发布包由 MANIFEST.in 排除）
docs/
tests/
